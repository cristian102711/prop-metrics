generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Tenant {
    id        String   @id @default(cuid())
    name      String
    slug      String   @unique
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    users    User[]
    projects Project[]
}

model User {
    id        String   @id @default(cuid())
    email     String   @unique
    name      String?
    role      Role     @default(INVESTOR)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    tenantId    String
    tenant      Tenant       @relation(fields: [tenantId], references: [id])
    investments Investment[]
}

enum Role {
    ADMIN
    INVESTOR
}

model Project {
    id            String      @id @default(cuid())
    name          String
    location      String
    type          ProjectType
    capRate       Float
    tir           Float
    minAmount     Float
    totalTokens   Int
    soldTokens    Int         @default(0)
    durationYears Int
    active        Boolean     @default(true)
    createdAt     DateTime    @default(now())
    updatedAt     DateTime    @updatedAt

    tenantId    String
    tenant      Tenant       @relation(fields: [tenantId], references: [id])
    investments Investment[]
    dividends   Dividend[]
}

enum ProjectType {
    RENTA
    DESARROLLO
    SOCIO_PREFERENTE
}

model Investment {
    id        String   @id @default(cuid())
    amount    Float
    tokens    Int
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    userId    String
    user      User    @relation(fields: [userId], references: [id])
    projectId String
    project   Project @relation(fields: [projectId], references: [id])
}

model Dividend {
    id     String   @id @default(cuid())
    amount Float
    paidAt DateTime @default(now())

    projectId String
    project   Project @relation(fields: [projectId], references: [id])
}

model Notification {
    id      String           @id @default(cuid())
    type    NotificationType
    channel String
    message String
    sentAt  DateTime         @default(now())
}

enum NotificationType {
    DIVIDEND_PAID
    PROJECT_FUNDED
    WEEKLY_REPORT
    TOKEN_AVAILABLE
}
